)
# Gráfico 3: Protestas por seguridad ciudadana durante el gobierno de Dina Boluarte
data %>%
filter(Presidente == "Boluarte Zegarra") %>%
group_by(Sub_Reclamo, Año, Mes_id) %>%
summarise(n = n(), .groups = "drop") %>%
complete(Sub_Reclamo, Año, Mes_id, fill = list(n = 0)) %>%
filter(Sub_Reclamo == "Seguridad") %>%
unite("fecha", Año, Mes_id, sep = "-") %>%
slice(-1:-11) %>%
mutate(fecha = factor(fecha, levels = unique(fecha[order(
as.numeric(sub("-.*", "", fecha)),   # order by year
as.numeric(sub(".*-", "", fecha))    # then by month number
)]))) %>%
ggplot(
aes(x=fecha, y=n)
) +
geom_col() +
theme_classic() +
labs(
title = "Protestas por seguridad ciudadana durante el gobierno de Dina Boluarte",
x = "Año y Mes",
y = "N° de protestas",
caption = "Fuente: Aragón, Jorge, Moisés Arce, Renzo Aurazo y Omar Coronel (2024).\nBase de Eventos de Protestas del Perú, Versión Enero 2024. Pontificia Universidad Católica del Perú.\nElaboración: Gianfranco Romero."
) +
scale_x_discrete(expand = c(0.01, 0.01)) +
scale_y_continuous(breaks = seq(0,70, by=5),
limits = c(0,70)) +
theme(
axis.text.x = element_text(angle = 45, vjust = 0.8, hjust = 0.5),
panel.grid.major.y = element_line(colour = "gray",
linetype = "dashed")
)
