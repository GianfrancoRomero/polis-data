# Librerías
library(rio)
library(tidyverse)
# Establecer directorio de trabajo
#setwd("~/GitHub/polis-data/protestas_genz")
# Importar data
data = readxl::read_excel("Base de Eventos de Protesta del Perú_1980_2025.xlsx", sheet = 2)
# Gráfico 1: Protestas por seguridad ciudadana en el Perú (1980-2024)
protestas_anio <- data %>%
group_by(
Sub_Reclamo,
Año
) %>%
summarise(
n = n(),
.groups = "drop"
) %>%
complete(
Sub_Reclamo,
Año,
fill = list(n = 0)
) %>%
filter(
Sub_Reclamo == "Seguridad"
) %>%
ggplot(
aes(
x=Año,
y=n
)
) +
geom_col() +
theme_classic() +
labs(
title = "Protestas por seguridad ciudadana en el Perú (1980-2024)",
subtitle = "Número de protestas reclamando por seguridad frente a la delincuencia",
x = "Año",
y = "N° de protestas",
caption = "Fuente: Aragón, Jorge, Moisés Arce, Renzo Aurazo y Omar Coronel (2024).\nBase de Eventos de Protestas del Perú, Versión Enero 2024. Pontificia Universidad Católica del Perú.\nElaboración: Gianfranco Romero."
) +
scale_x_continuous(
breaks = unique(data$Año),
expand = c(0.01, 0.01)
) +
scale_y_continuous(
breaks = seq(0,160, by=10),
limits = c(0,160)
) +
theme(
axis.text.x = element_text(angle = 90, vjust = 0.5),
panel.grid.major.y = element_line(colour = "gray",
linetype = "dashed")
)
# Exportamos gráfico 1
ggsave(
filename = "protestas_anio.svg",
plot = protestas_anio,
width = 9,
height = 6
)
# Gráfico 2: Protestas por seguridad por presidente
protestas_presi <- data %>%
group_by(Sub_Reclamo, Presidente) %>%
summarise(n = n(), .groups = "drop") %>%
complete(Sub_Reclamo, Presidente, fill = list(n = 0)) %>%
filter(Sub_Reclamo == "Seguridad") %>%
mutate(Presidente = factor(
Presidente,
levels = c("Morales Bermúdez", "Belaúnde Terry", "García Pérez(1)",
"Fujimori Fujimori(1)", "Fujimori Fujimori(2)", "Fujimori Fujimori(3)",
"Paniagua Corazao", "Toledo Manrique", "García Pérez(2)", "Humala Tasso",
"Kuczynski Godard", "Vizcarra Cornejo", "Merino Lama",
"Sagasti Hochhausler", "Castillo Terrones", "Boluarte Zegarra")
)
) %>%
ggplot(
aes(x=Presidente, y=n)
) +
geom_col() +
theme_classic() +
labs(
title = "Protestas por seguridad ciudadana por presidente",
subtitle = "Número de protestas por cada periodo presidencial",
x = "Presidente",
y = "N° de protestas",
caption = "Fuente: Aragón, Jorge, Moisés Arce, Renzo Aurazo y Omar Coronel (2024).\nBase de Eventos de Protestas del Perú, Versión Enero 2024. Pontificia Universidad Católica del Perú.\nElaboración: Gianfranco Romero."
) +
scale_x_discrete(labels = c(
"Morales Bermúdez" = "Morales Bermúdez",
"Belaúnde Terry" = "Belaúnde Terry",
"García Pérez(1)" = "A. García (1er gob.)",
"Fujimori Fujimori(1)" = "Fujimori (1er gob.)",
"Fujimori Fujimori(2)" = "Fujimori (2do gob.)",
"Fujimori Fujimori(3)" = "Fujimori (3er gob.)",
"Paniagua Corazao" = "Valentín Paniagua",
"Toledo Manrique" = "Alejandro Toledo",
"García Pérez(2)" = "A. García (2do gob.)",
"Humala Tasso" = "Ollanta Humala",
"Kuczynski Godard" = "PPK",
"Vizcarra Cornejo" = "Matín Vizcarra",
"Merino Lama" = "Manuel Merino",
"Sagasti Hochhausler" = "Francisco Sagasti",
"Castillo Terrones" = "Pedro Castillo",
"Boluarte Zegarra" = "Dina Boluarte")) +
scale_y_continuous(breaks = seq(0,170, by=10),
limits = c(0,170),
expand = c(0.01, 0.01)) +
theme(
panel.grid.major.x = element_line(colour = "gray",
linetype = "dashed")
) +
coord_flip()
# Exportamos gráfico 2
ggsave(
filename = "protestas_presi.svg",
plot = protestas_presi,
width = 9,
height = 6
)
# Gráfico 3: Protestas por seguridad ciudadana durante el gobierno de Dina Boluarte
